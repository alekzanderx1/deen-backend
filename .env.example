# =============================================================================
# Deen Backend — Environment Variables Template
# Copy this file to .env and fill in the real values.
# As of v1.1: COGNITO_REGION and COGNITO_POOL_ID are REMOVED.
#             SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY replace them.
# As of v1.2: OpenAI credentials REMOVED. ANTHROPIC_API_KEY replaces them. HuggingFace embeddings require no API key.
# =============================================================================

# === Anthropic ===
ANTHROPIC_API_KEY=your-anthropic-api-key-here
LARGE_LLM=claude-sonnet-4-6
SMALL_LLM=claude-haiku-4-5-20251001

# === Pinecone ===
PINECONE_API_KEY=your-pinecone-api-key-here
# General Islamic content indexes (hadith, Quran)
DEEN_DENSE_INDEX_NAME=deen-dense
DEEN_SPARSE_INDEX_NAME=deen-sparse
QURAN_DENSE_INDEX_NAME=quran-dense
# Fiqh-specific indexes (Sistani rulings) — optional at server startup; required for fiqh queries
DEEN_FIQH_DENSE_INDEX_NAME=deen-fiqh-dense
DEEN_FIQH_SPARSE_INDEX_NAME=deen-fiqh-sparse
# Retrieval weights (must sum to 1.0)
DENSE_RESULT_WEIGHT=0.8
SPARSE_RESULT_WEIGHT=0.2
REFERENCE_FETCH_COUNT=10

# === Supabase (replaces AWS Cognito as of v1.1) ===
# Project URL — found in Supabase Dashboard > Project Settings > API
SUPABASE_URL=https://xxxx.supabase.co
# Service role key (secret) — Supabase Dashboard > Project Settings > API > service_role
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# === Database (Supabase Postgres — direct connection, port 5432) ===
# Use the direct connection string, NOT the transaction pooler (port 6543 is incompatible with asyncpg)
DATABASE_URL=postgresql://postgres.xxxx:your-db-password-here@aws-0-us-east-1.pooler.supabase.com:5432/postgres
ASYNC_DATABASE_URL=postgresql+asyncpg://postgres.xxxx:your-db-password-here@aws-0-us-east-1.pooler.supabase.com:5432/postgres
# Individual components (alternative to DATABASE_URL — used if DATABASE_URL is not set)
DB_HOST=aws-0-us-east-1.pooler.supabase.com
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres.xxxx
DB_PASSWORD=your-db-password-here

# === Redis ===
REDIS_URL=redis://localhost:6379/0
REDIS_KEY_PREFIX=dev:chat
REDIS_TTL_SECONDS=12000
REDIS_MAX_MESSAGES=30

# === Memory / Personalization ===
# Embedding model used for user memory note vectors (dimension count for HuggingFace all-mpnet-base-v2)
EMBEDDING_MODEL=sentence-transformers/all-mpnet-base-v2
# Dimension count for HuggingFace all-mpnet-base-v2
EMBEDDING_DIMENSIONS=768
# Minimum relevance score for a memory note to be included in context (0.0–1.0)
NOTE_FILTER_THRESHOLD=0.4
# Minimum quality score required before a memory signal is stored (0.0–1.0)
SIGNAL_QUALITY_THRESHOLD=0.5

# === App ===
# ENV controls dev bypass behavior: "development" enables auth bypass for local testing
ENV=development
CORS_ALLOW_ORIGINS=http://localhost:3000
