# 🔹 Ignore Python cache and compiled files
__pycache__/
*.py[cod]
*.so
*.DS_Store

# 🔹 Ignore Virtual Environment
venv/
venv1/
.env/
*.venv
*.venv1

# 🔹 Ignore API Keys & Credentials
.env
openai_api_key.txt
pinecone_api_key.txt

# 🔹 Ignore Model Checkpoints & Hugging Face Cache
*.bin
*.ckpt
*.h5
*.tflite
model/
huggingface/
transformers_cache/
~/.cache/huggingface/
~/.cache/torch/

# 🔹 Ignore Log Files
logs/
*.log

# 🔹 Ignore Jupyter Notebook Checkpoints (if used)
.ipynb_checkpoints/

*.tar
*.whl

# 🔹 Ignore IDE & Editor Files
.vscode/
.idea/
*.iml
*.swp
*.swo
*.bak

# 🔹 Ignore Database Files (if applicable)
*.db
*.sqlite3

# 🔹 Ignore temps folder
temps/
.claude/
examples/
docs/

# Fiqh ingestion artifacts (generated, not committed)
data/*.json

